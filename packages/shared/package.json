{
  "name": "@firip/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, constants, and the Florida county/source data registry for FIRIP",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./data/*": "./data/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
