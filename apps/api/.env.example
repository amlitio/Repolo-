# --- Database ---
# Production/dev: Postgres + PostGIS, async driver.
DATABASE_URL=postgresql+asyncpg://firip:firip@localhost:5432/firip
# Test suite default (no live Postgres required): sqlite+aiosqlite:///:memory:
# DATABASE_URL=sqlite+aiosqlite:///:memory:

# --- App metadata ---
APP_NAME=firip-api
APP_VERSION=0.1.0
ENVIRONMENT=development
GIT_SHA=
BUILD_TIME=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Auth (Clerk) ---
CLERK_JWKS_URL=https://YOUR-CLERK-DOMAIN/.well-known/jwks.json
CLERK_ISSUER=https://YOUR-CLERK-DOMAIN
CLERK_AUDIENCE=
# NEVER enable in a deployed environment. Bypasses Clerk JWT verification for local dev/tests.
AUTH_DEV_BYPASS=0

# --- Outbound connector network gate ---
# Connector tests/jobs that would make real outbound HTTP calls are skipped unless this is set.
RUN_LIVE_SMOKE_TESTS=0

# --- NWS / NOAA ---
NWS_USER_AGENT=firip.app (ops@firip.app)

# --- LLM providers (optional; research agent is "not configured" if absent) ---
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Notifications (optional; /notifications/test simulates if absent) ---
NOTIFICATIONS_PROVIDER=
NOTIFICATIONS_API_KEY=
