# apps/workers imports apps/api's Settings class directly (app.config.get_settings),
# so it reads the exact same variables as apps/api/.env.example. pydantic-settings
# resolves `env_file=".env"` relative to the process's current working directory,
# so when running `python -m worker.scheduler` from apps/workers/, copy this file to
# apps/workers/.env (not apps/api/.env) for local development.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://firip:firip@localhost:5432/firip
# Test suite default (no live Postgres required): sqlite+aiosqlite:///:memory:
# DATABASE_URL=sqlite+aiosqlite:///:memory:

# --- App metadata ---
APP_NAME=firip-workers
APP_VERSION=0.1.0
ENVIRONMENT=development

# --- Outbound connector network gate ---
# Connector tests/jobs that would make real outbound HTTP calls are skipped unless this is set.
RUN_LIVE_SMOKE_TESTS=0

# --- NWS / NOAA ---
NWS_USER_AGENT=firip.app (ops@firip.app)

# --- LLM providers (optional; research agent is "not configured" if absent) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
