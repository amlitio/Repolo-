# FIRIP web frontend environment variables.
# Copy this file to .env.local and fill in real values for local development.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser bundle - never
# put secrets there.

# Base URL of the FastAPI backend (apps/api). No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mapbox GL JS public access token. Without this, MapCanvas renders a
# "Set NEXT_PUBLIC_MAPBOX_TOKEN to load the map" placeholder instead of
# crashing.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Clerk authentication (https://dashboard.clerk.com).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional product analytics (PostHog). Leave blank to disable.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Optional error monitoring (Sentry). Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=
